{
    "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
    "tasks": [
        {
            "name": "dotnet-format-lib-staged-files",
            "command": "dotnet",
            "args": [
                "format",
                "lib/TransmissionHub.Client.sln",
                "--verify-no-changes",
                "--include",
                "${staged}"
            ],
            "include": [
                "lib/**/*.cs"
            ]
        },
        {
            "name": "dotnet-format-bot-staged-files",
            "command": "dotnet",
            "args": [
                "format",
                "bot/TransmissionHub.TelegramBot.sln",
                "--verify-no-changes",
                "--include",
                "${staged}"
            ],
            "include": [
                "bot/**/*.cs"
            ]
        },
        {
            "name": "dotnet-build-lib",
            "command": "dotnet",
            "args": [
                "build",
                "lib/TransmissionHub.Client.sln",
                "--no-restore"
            ],
            "include": [
                "lib/**/*"
            ]
        },
        {
            "name": "dotnet-build-bot",
            "command": "dotnet",
            "args": [
                "build",
                "bot/TransmissionHub.TelegramBot.sln",
                "--no-restore"
            ],
            "include": [
                "bot/**/*"
            ]
        },
        {
            "name": "dotnet-test",
            "command": "dotnet",
            "args": [
                "test",
                "lib/TransmissionHub.Client.sln",
                "--filter",
                "Category=Unit"
            ],
            "include": [
                "lib/**/*"
            ]
        },
        {
            "name": "commit-message-linter",
            "command": "dotnet",
            "args": [
                "husky",
                "exec",
                ".husky/csx/commit-lint.csx",
                "--args",
                "${args}"
            ]
        }
    ]
}